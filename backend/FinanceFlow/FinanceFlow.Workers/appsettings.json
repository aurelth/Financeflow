{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Api": {
    "BaseUrl": "https://localhost:7195/"
  },
  "ServiceAuth": {
    "ServiceKey": "CHANGE_ME_IN_PRODUCTION"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "budget-alert-worker",
    "ReportConsumerGroupId": "report-generator-worker",
    "Topics": {
      "TransactionCreated": "finance.transactions.created",
      "BudgetAlerts": "finance.budget.alerts",
      "NotificationsCreated": "finance.notifications.created",
      "ReportsRequested": "finance.reports.requested"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  }
}
