{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  {
    "Api": {
      "BaseUrl": "https://localhost:7001/"
    },
    "ServiceAuth": {
      "ServiceKey": "CHANGE_ME_IN_PRODUCTION"
    },
    "Kafka": {
      "BootstrapServers": "localhost:9092",
      "ConsumerGroupId": "budget-alert-worker",
      "Topics": {
        "TransactionCreated": "finance.transactions.created",
        "BudgetAlerts": "finance.budget.alerts",
        "NotificationsCreated": "finance.notifications.created"
      }
    },
    "Serilog": {
      "MinimumLevel": "Information"
    }
  }
}
