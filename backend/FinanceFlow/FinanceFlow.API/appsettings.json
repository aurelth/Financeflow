{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/financeflow-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "FinanceFlow",
    "Audience": "FinanceFlowUsers",
    "ExpirationMinutes": 60
  },
  "Redis": {
    "ConnectionString": ""
  },
  "Kafka": {
    "BootstrapServers": "",
    "GroupId": "financeflow-group",
    "Topics": {
      "TransactionCreated": "finance.transactions.created",
      "ReportsRequested": "finance.reports.requested",
      "BudgetAlerts": "finance.budget.alerts"
    }
  },
  "Storage": {
    "BasePath": "storage"
  }
}
